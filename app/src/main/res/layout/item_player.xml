<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="112dp"
    android:layout_height="174dp"
    android:background="@drawable/shape_player"
    android:layout_marginBottom="1dp"
    android:layout_marginTop="8dp"
    android:paddingBottom="5dp">

    <ImageView
        android:id="@+id/img_PlayerProfile"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_marginTop="-12dp"
        android:src="@drawable/profile"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:visibility="gone"
        android:id="@+id/img_LevelBar"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginStart="3dp"
        android:layout_marginTop="-44dp"
        android:layout_marginEnd="3dp"
        android:src="@drawable/level"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/img_PlayerProfile" />

    <TextView
        android:id="@+id/txt_PlayerName"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:layout_marginStart="2dp"
        android:text="اسم پلیر"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSecondary"
        android:fontFamily="@font/baloobhaijaan2_medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/img_PlayerProfile" />

    <ImageView
        android:id="@+id/img_Coin"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="16dp"
        android:padding="0dp"
        android:scaleType="fitXY"
        android:src="@drawable/ic_gold_foreground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_PlayerName" />

    <TextView
        android:id="@+id/txt_PayedPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:text="0"
        android:textSize="12sp"
        android:textColor="?attr/colorOnSecondary"
        android:fontFamily="@font/baloobhaijaan2_medium"
        app:layout_constraintBottom_toBottomOf="@+id/img_Coin"
        app:layout_constraintStart_toEndOf="@+id/img_Coin"
        app:layout_constraintTop_toTopOf="@+id/img_Coin" />

    <ImageView
        android:id="@+id/img_Time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:src="@drawable/clock"
        app:layout_constraintStart_toStartOf="@+id/img_Coin"
        app:layout_constraintEnd_toEndOf="@+id/img_Coin"
        app:layout_constraintTop_toBottomOf="@+id/img_Coin" />

    <TextView
        android:id="@+id/txt_PlayedTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="12sp"
        android:textColor="?attr/colorOnSecondary"
        android:fontFamily="@font/baloobhaijaan2_medium"
        app:layout_constraintBottom_toBottomOf="@+id/img_Time"
        app:layout_constraintStart_toStartOf="@+id/txt_PayedPrice"
        app:layout_constraintTop_toTopOf="@+id/img_Time" />

</androidx.constraintlayout.widget.ConstraintLayout>