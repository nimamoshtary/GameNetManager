<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/shape_edittext"
    android:backgroundTint="?attr/background"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_show"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible"
        android:background="?attr/background" >

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/RecyclerOperator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btn_addOperator"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_addOperator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="5dp"
            android:text="افزودن اپراتور"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/shape_edittext"
            app:backgroundTint="#4E044C" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_add"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="?attr/background"
        tools:ignore="MissingConstraints">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/edt_StartTime"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="50dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="20dp"
            android:hint="اسم نمایشی اپراتور"
            app:hintTextColor="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/shape_edittext"
                android:inputType="text"
                android:padding="2dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/autoCompleteOP"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="200dp"
            android:layout_height="55dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:hint="انتخاب مدل اپراتور . . ."
            app:hintTextColor="@color/white"
            android:padding="0dp"
            app:layout_constraintEnd_toEndOf="@+id/edt_StartTime"
            app:layout_constraintTop_toBottomOf="@+id/edt_StartTime">
            <AutoCompleteTextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/shape_edittext"
                android:inputType="none"
                android:padding="0dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:id="@+id/BoardGame"
            android:layout_width="225dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/autoCompleteOP"
            app:layout_constraintEnd_toEndOf="@+id/autoCompleteOP"
            android:gravity="end"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/edt_PriceBG"
                android:layout_width="200dp"
                android:layout_height="50dp"
                android:hint="قیمت ساعتی به ازای هر نفر"
                app:hintTextColor="@color/white">
                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/shape_edittext"
                    android:inputType="number"
                    android:padding="2dp"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/Console"
            android:layout_width="260dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="@+id/autoCompleteOP"
            app:layout_constraintTop_toBottomOf="@+id/BoardGame"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="260dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="30dp"
                    android:src="@drawable/gamepad_fg" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/edt_PriceC_One"
                    android:layout_width="180dp"
                    android:layout_height="50dp"
                    android:layout_gravity="end"
                    android:layout_marginEnd="80dp"
                    android:hint="قیمت ساعتی"
                    app:hintTextColor="@color/white">

                    <com.google.android.material.textfield.TextInputEditText
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/shape_edittext"
                        android:inputType="number"
                        android:padding="2dp" />
                </com.google.android.material.textfield.TextInputLayout>
            </FrameLayout>

            <FrameLayout
                android:layout_width="260dp"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2"
                    android:textSize="20dp"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="end|center_vertical"/>
                <ImageView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="30dp"
                    android:src="@drawable/gamepad_fg"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/edt_PriceC_Two"
                    android:layout_width="180dp"
                    android:layout_height="50dp"
                    android:layout_gravity="end"
                    android:layout_marginEnd="80dp"
                    android:hint="قیمت ساعتی"
                    app:hintTextColor="@color/white">

                    <com.google.android.material.textfield.TextInputEditText
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/shape_edittext"
                        android:inputType="number"
                        android:padding="2dp" />
                </com.google.android.material.textfield.TextInputLayout>
            </FrameLayout>

            <FrameLayout
                android:layout_width="260dp"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textSize="20dp"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="end|center_vertical"/>
                <ImageView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="30dp"
                    android:src="@drawable/gamepad_fg"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/edt_PriceC_Three"
                    android:layout_width="180dp"
                    android:layout_height="50dp"
                    android:layout_gravity="end"
                    android:layout_marginEnd="80dp"
                    android:hint="قیمت ساعتی"
                    app:hintTextColor="@color/white">

                    <com.google.android.material.textfield.TextInputEditText
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/shape_edittext"
                        android:inputType="number"
                        android:padding="2dp" />
                </com.google.android.material.textfield.TextInputLayout>
            </FrameLayout>

            <FrameLayout
                android:layout_width="260dp"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4"
                    android:textSize="20dp"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="end|center_vertical"/>
                <ImageView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="30dp"
                    android:src="@drawable/gamepad_fg"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/edt_PriceC_four"
                    android:layout_width="180dp"
                    android:layout_height="50dp"
                    android:layout_gravity="end"
                    android:layout_marginEnd="80dp"
                    android:hint="قیمت ساعتی"
                    app:hintTextColor="@color/white">

                    <com.google.android.material.textfield.TextInputEditText
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/shape_edittext"
                        android:inputType="number"
                        android:padding="2dp" />
                </com.google.android.material.textfield.TextInputLayout>
            </FrameLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ok"
            android:layout_width="70dp"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:padding="0dp"
            android:text="اتمام"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="#4E044C"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/Console" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>